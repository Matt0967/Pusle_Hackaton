{
  "name": "pulse-ecosysteme-energetique-vivant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "build:gh-pages": "tsc && vite build --base=/Pusle_Hackaton/",
    "build:docs": "npm run build:gh-pages && node scripts/copy-dist-to-docs.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc --noEmit",
    "verify:render": "node scripts/verify-render.mjs",
    "verify:onboarding": "node scripts/verify-onboarding.mjs",
    "verify:hud-drag": "node scripts/verify-hud-drag.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "playwright-core": "^1.61.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
